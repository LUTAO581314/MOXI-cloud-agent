[Unit]
Description=bairui platform API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/bairui/moxi-cloud-agent
EnvironmentFile=/etc/bairui/platform.env
ExecStart=/usr/bin/npm run platform:dev
Restart=always
RestartSec=5
User=bairui
Group=bairui
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/lib/bairui /opt/bairui/moxi-cloud-agent

[Install]
WantedBy=multi-user.target
