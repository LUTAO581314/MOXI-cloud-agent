# Copy this file to a protected server path such as /etc/bairui/platform.env.
# Do not commit real production values.

BAIRUI_PLATFORM_PORT=8788
BAIRUI_PLATFORM_DATABASE_URL=postgres://bairui:change-me@127.0.0.1:5432/bairui_platform
BAIRUI_SERVER_AGENT_TOKEN=change-me-long-random-token
BAIRUI_SERVER_REGISTRY_PATH=/var/lib/bairui/platform/server-registry.json
